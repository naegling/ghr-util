#!/usr/bin/env python3

import argparse
import platform
import yaml
import sys
import os
import shutil
import shlex
import subprocess
import re
import tempfile
import requests
import functools
from github import Github
from github import Auth
from github import GithubException

MODE_LIST = 1
MODE_INFO = 2
MODE_DOWNLOAD = 3
MODE_UPDATE = 4
MODE_INSTALL = 5


# Global data
ARCH = platform.uname()
ARCH_SYSTEM = ARCH.system.lower()
ARCH_MACHINE = ARCH.machine.lower()
ALT_MACHINE_KEYWORDS = {
                        'x86_64' :  ['amd64']
                        }

DEB_EXTENSIONS = ['.deb']
TAR_EXTENSIONS = ['.tar', '.tar.gz', '.tgz', '.tar.bz2', '.tbz', '.tar.xz', '.txz']
TMPDIR = os.path.join(tempfile.gettempdir(), "ghr-util")

def fatal(ret_code, str = None):
  if str is not None:
    print(f"{str}", file=sys.stderr)
  exit(ret_code)


def is_nonempty_str(s):
  return s is not None and isinstance(s, str) and len(s) > 0


def ensure_binaries(prgs):
  if isinstance(prgs, str):
    if shutil.which(prgs) is None:
      fatal(1, f"{prgs} is required, but not found")
    return True
  elif hasattr(prgs, '__iter__'):
    for prg in prgs:
      ensure_binaries(prg)


def get_machine_keywords():
  keywords = [ ARCH_MACHINE ]
  if ARCH_MACHINE in ALT_MACHINE_KEYWORDS:
    if isinstance(ALT_MACHINE_KEYWORDS[ARCH_MACHINE], str):
      keywords.append(ALT_MACHINE_KEYWORDS[ARCH_MACHINE])
    elif hasattr(ALT_MACHINE_KEYWORDS[ARCH_MACHINE], '__iter__'):
      keywords.extend(ALT_MACHINE_KEYWORDS[ARCH_MACHINE])
  return keywords


def run_prog(prog, args=None, cwd=None, input=None, fatal_fail=False):

  if args is not None:
    run_args = [prog]
    run_args.extend(args)
  else:
    run_args = shlex.split(prog)

  try:
    result = subprocess.run(run_args, input=input, capture_output=True, text=True, cwd=cwd)
  except:
    if fatal_fail:
      fatal(1, f"Failed to execute: {" ".join(run_args)}")
    return None

  if result.returncode != 0:
    if fatal_fail:
      fatal(1, f"Failed to execute: {" ".join(run_args)}\nReturn Code {result.returncode}\n{result.stderr}")
    return None

  return result.stdout


def select_asset(names, exts, require, disallow, prefer, avoid):

  name_tags = {}

  # gotta consider all of the possible extensions
  for name in names:
    for ext in exts:
      if name.endswith(ext):
        tmp = name[:-len(ext)]
        # deal with annoying case of a token with an embedded split char
        tmp = tmp.replace('x86_64', 'x86@64')
        tmp = re.split(r'-|_|\.', tmp)
        name_tags[name] = [ s.lower().replace('x86@64', 'x86_64') for s in tmp ]
        break

  candidates = list(name_tags.keys())

  # first only consider candidates that include required
  for keyword in require:
    candidates = [ name for name in candidates if keyword in name_tags[name] ]

  # now discard the candidates in disallowed
  for keyword in disallow:
    candidates = [ name for name in candidates if keyword not in name_tags[name] ]

  # if this is down to a single candiate, then we're done
  if len(candidates) > 0:

    # try each of the ARCH_MACHINE keywords
    for keyword in get_machine_keywords():
      potentials = [ name for name in candidates if keyword in name_tags[name] ]
      if len(potentials) > 0:
        candidates = potentials

    # still have a choice to make
    if len(candidates) > 1:

      # try to filter based on system.  revert if no remaining candidate
      potentials = [ name for name in candidates if ARCH_SYSTEM in name_tags[name] ]
      if len(potentials) > 0:
        candidates = potentials

      # still have a choice to make
      if len(candidates) > 1:

        for keyword in prefer:
          potentials = [ name for name in candidates if keyword in name_tags[name] ]
          if len(potentials) > 0:
            if len(potentials) == 1:
              return potentials
            else:
              candidates = potentials

        for keyword in avoid:
          potentials = [ name for name in candidates if keyword not in name_tags[name] ]
          if len(potentials) > 0:
            if len(potentials) == 1:
              return potentials
            else:
              candidates = potentials

  return candidates


@functools.total_ordering
class Version:

  def __init__(self, s=None):
    self.major = 0
    self.minor = 0
    self.patch = 0
    if is_nonempty_str(s):
      match = re.match(r'.*?([0-9.]+).*?', s)
      if match:
        s = match.group(1)
        if len(s) > 0:
          segs = s.split('.')
          if len(segs) > 0:
            self.major = int(segs[0])
            if len(segs) > 1:
              self.minor = int(segs[1])
              if len(segs) > 2:
                self.patch = int(segs[2])

  def _is_valid_operand(self, other):
    return hasattr(other, 'major') and hasattr(other, 'minor') and hasattr(other, 'patch')

  def __eq__(self, other):
    if not self._is_valid_operand(other):
      return NotImplemented
    return self.major == other.major and self.minor == other.minor and self.patch == other.patch

  def __lt__(self, other):
    if not self._is_valid_operand(other):
      return NotImplemented
    return (self.major, self.minor, self.patch) < (other.major, other.minor, other.patch)

  def __str__(self):
    if self.major == 0 and self.minor == 0 and self.patch == 0:
      return f"None"
    return f"{self.major}.{self.minor}.{self.patch}"

  def is_missing(self):
    return self.major == 0 and self.minor == 0 and self.patch == 0


class BasePkgHandler:

  def __init__(self):
    pass

  def get_type(self):
    return 'base'

  def set_pkg(self, name, pkg, prefs):
    self.name = name
    self.repo = pkg['repo']
    self.require =  prefs['require']  + pkg['require']
    self.disallow = prefs['disallow'] + pkg['disallow']
    self.prefer =   prefs['prefer']   + pkg['prefer']
    self.avoid =    prefs['avoid']    + pkg['avoid']

  def get_installed_ver(self):
    return None

  def select_asset(self, candidates):
    return None

  def install(self, fname):
    return False


class DebPkgHandler(BasePkgHandler):

  def __init__(self):
    super().__init__()

  def get_type(self):
    return 'deb'

  def get_installed_ver(self):
    result = run_prog(f"dpkg-query --show {self.name}")
    if is_nonempty_str(result):
      result = result.split()
      if len(result) > 1:
        result = result[1]
        return Version(result.split('-')[0])
    return Version()

  def select_asset(self, candidates):
    return select_asset(candidates, DEB_EXTENSIONS, self.require, self.disallow, self.prefer, self.avoid)

  def install(self, fname):
    result = subprocess.run(['sudo', 'bash', '-c', 'apt install ' + fname])
    if result.returncode == 0:
      return True
    return False


class TarballPkgHandler(BasePkgHandler):

  def __init__(self):
    super().__init__()

  def get_type(self):
    return 'tar'

  def set_pkg(self, name, pkg, prefs):
    super().set_pkg(name, pkg, prefs)
    self.ver_cmd = pkg['ver_cmd']
    self.ver_match = pkg.get('ver_match', None)
    self.install_script = pkg.get('install', None)

  def get_installed_ver(self):
    result = run_prog(self.ver_cmd)
    if is_nonempty_str(result):
      # just the 1st line
      result = result.split("\n")[0]
      if self.ver_match is not None:
        match = re.match(self.ver_match, result)
        if match:
          result = match.group(1)
      return Version(result)
    return Version()

  def select_asset(self, candidates):
    return select_asset(candidates, TAR_EXTENSIONS, self.require, self.disallow, self.prefer, self.avoid)

  def install(self, fname):
    path, file = os.path.split(fname)
    print(f"Extracting {file} ... ", end='')
    result = run_prog(f"tar -xf {fname}", cwd=path)
    if result is None:
      print(f"Failed.")
    else:
      print(f"Done.")
      if is_nonempty_str(self.install_script):
        print(f"Installing {self.name} ... ", end='')
        result = subprocess.run(['sudo', 'bash', '-c', self.install_script], cwd=path)
        if result.returncode == 0:
          print("Done.")
          return True
        else:
          print("Failed.")
          print(f"Install script for {self.name} failed. Manually install {fname}")
      else:
        print(f"Automatic installation of tarball for {self.name} is not configured. Manually install {fname}")
    return False


def do_op(op, hdlr, gh, token, name, pkg, prefs):

  hdlr.set_pkg(name, pkg, prefs)
  installed_ver = hdlr.get_installed_ver()
  if op == MODE_INSTALL and not installed_ver.is_missing():
    # if install mode and any version is installed, return silently
    return

  print(f"{hdlr.get_type():<3} {name+":":<15} {str(installed_ver):<10}", end='')
  if op == MODE_LIST:
    # if we are only listing, then we are done
    print()
    return

  # get the repo's latest release
  release = None
  try:
    repo = gh.get_repo(hdlr.repo)
    if 'rel_match' in pkg:
      for rel in repo.get_releases():
        if re.match(pkg['rel_match'], rel.tag_name):
          release = rel
          break
    else:
      release = repo.get_latest_release()
  except GithubException as err:
    print(f"\nFailed: Github access for {name} at {hdlr.repo}: {err.status}.")
    return

  if release is None:
    print(f"\nFailed: Release not found for {name} at {hdlr.repo}.")
    return

  released_ver = Version(release.tag_name)
  if released_ver.is_missing():
    print(f"\nFailed: Unreadable release version for {name} at {hdlr.repo}.")
    return

  print(f" {str(released_ver):<10}", end='')

  # newer version on github, construct a map of assets
  assets = {}
  for asset in release.get_assets():
    assets[asset.name] = asset

  update_avail = (not released_ver.is_missing()) and (installed_ver.is_missing() or installed_ver < released_ver)
  if not update_avail:
    print("     ", end='')
  elif op == MODE_DOWNLOAD:
    print("down ", end='')
  else:
    print("inst ", end='')

  finalists = hdlr.select_asset(list(assets.keys()))
  if len(finalists) == 0:
    print("None", end='')
  elif len(finalists) > 1:
    print(", ".join(finalists), end='')
  else:
    finalist = finalists[0]
    asset = assets[finalist]
    print(f"{finalist}", end='')

    # if this is just for info or no update is available, we're all done
    if op != MODE_INFO:
      if op == MODE_INSTALL or update_avail:

        print(f"\n\nDownloading {asset.name} to {TMPDIR} ... ", end='')

        # download asset to tmp directory
        os.makedirs(TMPDIR, exist_ok=True)
        headers = {"Accept": "application/octet-stream"}
        if token is not None:
          headers["Authorization"] = f"token {token}"
        response = requests.Session().get(asset.url, stream=True, headers=headers)
        pathname = os.path.join(TMPDIR, asset.name)
        with open(pathname, "wb") as outfile:
          for chunk in response.iter_content(1024*1024):
            outfile.write(chunk)
        print("Done.")

        if op != MODE_DOWNLOAD:
          if hdlr.install(pathname):
            os.remove(pathname)
          else:
            print(f"Installation did not complete")

  print()


def main(args):

  # look if various places for a github token
  if args.token is None and args.op != MODE_LIST:

    # try the environment
    args.token = os.environ.get('GITHUB_GHR_TOKEN', None)
    if args.token is None:

      # still looking... try pass
      args.token = run_prog("pass github/ghr-token")
      if is_nonempty_str(args.token):
        args.token = args.token.split("\n")[0].strip()

  # load the configuration
  if os.pathsep not in args.file:

    # if just a filename, then look for file in default config directory
    if 'XDG_CONFIG_HOME' in os.environ:
      cfg_dir = os.path.join(os.environ['XDG_CONFIG_HOME'], 'host-config')
    elif 'HOME' in os.environ:
      cfg_dir = os.path.join(os.environ['HOME'], '.config', 'host-config')
    else:
      cfg_dir = None
    if cfg_dir is not None:
      args.file = os.path.join(cfg_dir, args.file)

  cfg = {}
  try:
    with open(args.file) as infile:
      cfg = yaml.safe_load(infile)
  except IOError as err:
    fatal(1, f"{err}")
  except Exception as err:
    fatal(1, f"Unexpected {err=}, {type(err)=}")

  # load global selection preferences first
  if 'global' not in cfg:
    cfg['global'] = {}
  global_prefs = {}
  for key in ['require', 'disallow', 'prefer', 'avoid']:
    global_prefs[key] = cfg['global'][key] if key in cfg['global'] and cfg['global'][key] is not None else []

  # get either an authorized or anonymous github instance
  if args.token is not None:
    auth = Auth.Token(args.token)
    gh = Github(auth=auth)
  else:
    gh = Github()

  for pkg_type, pkgs in cfg.items():
    hdlr = None
    if pkg_type == 'global':
      continue
    elif pkg_type == 'deb':
      hdlr = DebPkgHandler()
    elif pkg_type == 'tar':
      hdlr = TarballPkgHandler()

    if hdlr is None:
      print(f"Error: unsupported package type: {pkg_type}")
    else:
      for name, pkg in pkgs.items():
        # normalize the config. much simplier than checking for None everywhere
        for key in ['require', 'disallow', 'prefer', 'avoid']:
          if key not in pkg or pkg[key] is None:
            pkg[key] = []

        do_op(args.op, hdlr, gh, args.token, name, pkg, global_prefs)

  return 0


if __name__ == "__main__":

  map_modes = {
      "list": MODE_LIST,
      "info": MODE_INFO,
      "download": MODE_DOWNLOAD,
      "update": MODE_UPDATE,
      "install": MODE_INSTALL
    }

  ensure_binaries(['tar'])
  parser = argparse.ArgumentParser(prog='ghr-util', description='Utility for updating packages/binaries from Github releases', epilog='')
  parser.add_argument("op", choices=list(map_modes), help="Operation to perform.")
  parser.add_argument("--token", default=None, help="Github access token with repository read privledge")
  parser.add_argument("file", help="Configuration file (full pathname or filename in $XDG_CONFIG_DIR/host-config)")
  args = parser.parse_args()
  args.op = map_modes[args.op]
  exit(main(args))
