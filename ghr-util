#!/usr/bin/env python3

import argparse
import platform
import yaml
import sys
import os
import shutil
import subprocess
import re
import tempfile
from github import Github
from github import Auth
from github import GithubException
import requests
import semver

MODE_MAKE_IT_SO = 0
MODE_DOWNLOAD_ONLY = 1
MODE_DRY_RUN = 2


# Global data
ARCH = platform.uname()
ARCH_SYSTEM = ARCH.system.lower()
ARCH_MACHINE = ARCH.machine.lower()
ALT_MACHINE_KEYWORDS = {
                        'x86_64' :  ['amd64']
                        }
TAR_EXTENSIONS = ['.tar', '.tar.gz', '.tgz', '.tar.bz2', '.tbz', '.tar.xz', '.txz' ]
TMPDIR = os.path.join(tempfile.gettempdir(), "ghr-util")

def fatal(ret_code, str = None):
  if str is not None:
    print(f"{str}", file=sys.stderr)
  exit(ret_code)


def ensure_binaries(prgs):
  if isinstance(prgs, str):
    if shutil.which(prgs) is None:
      fatal(1, f"{prgs} is required, but not found")
    return True
  elif hasattr(prgs, '__iter__'):
    for prg in prgs:
      ensure_binaries(prg)


def get_machine_keywords():
  keywords = [ ARCH_MACHINE ]
  if ARCH_MACHINE in ALT_MACHINE_KEYWORDS:
    if isinstance(ALT_MACHINE_KEYWORDS[ARCH_MACHINE], str):
      keywords.append(ALT_MACHINE_KEYWORDS[ARCH_MACHINE])
    elif hasattr(ALT_MACHINE_KEYWORDS[ARCH_MACHINE], '__iter__'):
      keywords.extend(ALT_MACHINE_KEYWORDS[ARCH_MACHINE])
  return keywords


def run_prog(prog, args, input=None, silent_fail=True):
  run_args = [prog]
  run_args.extend(args)
  try:
    result = subprocess.run(run_args, input=input, capture_output=True, text=True)
  except:
    if not silent_fail:
      fatal(1, f"Failed to execute: {" ".join(run_args)}")
    return None

  if result.returncode != 0 or len(result.stderr) > 0:
    if not silent_fail:
      fatal(1, f"Failed to execute: {" ".join(run_args)}\nReturn Code {result.returncode}\n{result.stderr}")
    return None

  return result.stdout


def sanitize_semver(ver):
  # strip leading zeros
  ver = ver.lstrip('vV').strip()
  cleaned_ver = []
  for s in ver.split('.'):
    s = s.lstrip('0')
    if len(s) > 0:
      cleaned_ver.append(s)
    else:
      cleaned_ver.append('0')
  return ".".join(cleaned_ver)


class BasePkgHandler:
  def __init__(self, name):
    self.name = name

  def get_installed_ver(self):
    return None

  def select_asset(self, candidates):
    return None

  def install(self, fname):
    return False


class DebPkgHandler(BasePkgHandler):
  def __init__(self, name, repo):
    super().__init__(name)
    self.repo = repo

  def get_installed_ver(self):
    result = run_prog('dpkg-query', ['--show', self.name])
    if result is not None and isinstance(result, str) and len(result) > 0:
      result = result.split()
      if len(result) > 1:
        result = result[1]
        return sanitize_semver(result.split('-')[0])
    return None

  def select_asset(self, candidates):

    # the asset has to be a deb file
    candidates = [ name for name in candidates if name.endswith(".deb")]

    name_tags = {}
    for name in candidates:
      # TODO: cannot break on x86_64
      name_tags[name] = [ s.lower() for s in re.split(r'-|_|\.', name) ]

    # try to filter based on system.  revert is no remaining candidate
    potentials = [ name for name in candidates if ARCH_SYSTEM in name_tags[name] ]
    if len(potentials) > 0 and len(potentials) < len(candidates):
      candidates = potentials

    # machine is a bit more complicated due to multple word matches
    # try the ARCH_MACHINE first
    # try each in turn
    for keyword in get_machine_keywords():
      potentials = [ name for name in candidates if keyword in name_tags[name] ]
      if len(potentials) > 0 and len(potentials) < len(candidates):
        candidates = potentials

    # if we still have too many, try throwing out the musl
    if len(candidates) > 1:
      potentials = [ name for name in candidates if 'musl' not in name_tags[name] ]
      if len(potentials) > 0 and len(potentials) < len(candidates):
        candidates = potentials

    return candidates

  def install(self, fname):
    result = subprocess.run(['sudo', 'bash', '-c', 'apt install ' + fname])
    if result.returncode == 0:
      return True
    return False


class TarballPkgHandler(BasePkgHandler):
  def __init__(self, name, repo, cmd, args, match):
    super().__init__(name)
    self.repo = repo
    self.cmd = cmd
    self.args = args
    self.match = match

  def get_installed_ver(self):
    result = run_prog(self.cmd, self.args)
    if result is not None and len(result) > 0:
      result = result.split("\n")[0]
      match = re.match(self.match, result)
      if match:
        return sanitize_semver(match.group(1))
    return None

  def select_asset(self, candidates):

    # gotta consider all of the possible tarball extensions
    potentials = []
    for candidate in candidates:
      for ext in TAR_EXTENSIONS:
        if candidate.endswith(ext):
          potentials.append(candidate)
          break
    candidates = potentials

    name_tags = {}
    for name in candidates:
      # TODO: cannot break on x86_64
      name_tags[name] = [ s.lower() for s in re.split(r'-|_|\.', name) ]

    # try to filter based on system.  revert is no remaining candidate
    potentials = [ name for name in candidates if ARCH_SYSTEM in name_tags[name] ]
    if len(potentials) > 0 and len(potentials) < len(candidates):
      candidates = potentials

    # machine is a bit more complicated due to multple word matches
    # try the ARCH_MACHINE first
    # try each in turn
    for keyword in get_machine_keywords():
      potentials = [ name for name in candidates if keyword in name_tags[name] ]
      if len(potentials) > 0 and len(potentials) < len(candidates):
        candidates = potentials

    # if we still have too many, try throwing out the musl
    if len(candidates) > 1:
      potentials = [ name for name in candidates if 'musl' not in name_tags[name] ]
      if len(potentials) > 0 and len(potentials) < len(candidates):
        candidates = potentials

    return candidates

  def install(self, fname):
    return False


def update_package(gh, token, name, cfg, mode, verbose):

  pkg_type = cfg['type']
  installed_ver = None

  if pkg_type == 'deb':
    handler = DebPkgHandler(name, cfg['repo'])
  elif pkg_type == 'tar':
    handler = TarballPkgHandler(name, cfg['repo'], cfg['version_cmd'], cfg['version_args'], cfg['version_match'])
  else:
    fatal(1, f"Unhandled package type '{pkg_type}'.")

  installed_ver = handler.get_installed_ver()

  try:
    repo = gh.get_repo(cfg['repo'])
    release = repo.get_latest_release()
  except GithubException as err:
    print(f"Failed accessing github repo for {name}: {err.status}.")
    return

  released_ver = sanitize_semver(release.name)
  if verbose:
    print(f"Package {name}, Installed: {installed_ver}, released: {released_ver}.")
  if installed_ver is None or semver.compare(installed_ver, released_ver) < 0:

    if installed_ver is None:
      print(f"Installing {name} version {released_ver}.")
    else:
      print(f"Upgrading {name} version from {installed_ver} to {released_ver}.")

    # newer version on github
    assets = {}
    for asset in release.get_assets():
      assets[asset.name] = asset

    finalists = handler.select_asset(list(assets.keys()))
    if len(finalists) == 0:
      print(f"WARNING: Unable to find matching asset for {name} in release {released_ver}.")
    else:
      if len(finalists) > 1:
        print("WARNING: multiple viable candidates. Downloading all candidates and skipping installation.")

      for finalist in finalists:
        asset = assets[finalist]

        if mode == MODE_DRY_RUN:
          print(f"  Selected {asset.name} for download", end = "")
          if len(finalists) == 1:
            print(" and installation", end='')
          print(".")
        else:

          # download asset to tmp directory
          os.makedirs(TMPDIR, exist_ok=True)
          headers = { "Authorization": f"token {token}", "Accept": "application/octet-stream"}
          response = requests.Session().get(asset.url, stream=True, headers=headers)
          pathname = os.path.join(TMPDIR, asset.name)
          if verbose:
            print(f"Downloading {asset.name} ...", end = '')
          with open(pathname, "wb") as outfile:
            for chunk in response.iter_content(1024*1024):
              outfile.write(chunk)
          if verbose:
            print(" Done")

          if mode == MODE_DOWNLOAD_ONLY:
            print(f"Package {name} saved as {pathname}.")
          elif len(finalists) != 1:
            print(f"Installation skipped. Package {name} saved as {pathname}.")
          else:
            if handler.install(pathname):
              os.remove(pathname)
            else:
              print(f"Installation failed.  Downloaded file at: {pathname}")


def main(args):

  mode = MODE_DRY_RUN if args.dry_run else MODE_DOWNLOAD_ONLY if args.download else MODE_MAKE_IT_SO

  # load the configuration
  cfg = {}
  try:
    with open(args.file) as infile:
      cfg = yaml.safe_load(infile)
  except IOError as err:
    fatal(1, f"{err}")
  except Exception as err:
    fatal(1, f"Unexpected {err=}, {type(err)=}")

  # get an authorized github instance
  auth = Auth.Token(args.token)
  gh = Github(auth=auth)

  for pkg_name, pkg_cfg in cfg.items():
    update_package(gh, args.token, pkg_name, pkg_cfg, mode, args.verbose)

  return 0


if __name__ == "__main__":
  ensure_binaries([])
  parser = argparse.ArgumentParser(prog='ghr-util', description='Utility for updating packages/binaries from Github releases', epilog='')
  parser.add_argument("op", choices=['update'], help="Operation to perform.")
  parser.add_argument("--token", default=None, help="File to load/dump.")
  parser.add_argument("file", help="Configuration file.")
  parser.add_argument("-n", "--dry-run", action="store_true", help="Do not download packages, just say what would be done.")
  parser.add_argument("-v", "--verbose", action='store_true', help="Display extra messages")
  parser.add_argument("-d", "--download", action='store_true', help="Download packages without attemping installation")
  args = parser.parse_args()

  if args.download and args.dry_run:
    raise argparse.ArgumentError("Cannot combine 'dry-run' and 'download'")

  exit(main(args))
