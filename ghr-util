def main(args):

    # load the configuration
  if args.file is None:
    args.file = f"{os.environ['XDG_CONFIG_HOME']}" if 'XDG_CONFIG_HOME' in os.environ else f"{os.environ['HOME']}/.config" if 'HOME' in os.environ else ""
    args.file+="/host-config/ghr.yaml"

  cfg = {}
  try:
    with open(args.file) as infile:
      cfg = yaml.safe_load(infile)
  except IOError as err:
    fatal(1, f"{err}")
  except Exception as err:
    fatal(1, f"Unexpected {err=}, {type(err)=}")

  for pkg_type, pkgs in cfg.items():
    hdlr = None
    if pkg_type == 'deb':
      hdlr = DebPkgHandler()
    elif pkg_type == 'tar':
      hdlr = TarballPkgHandler()

    if hdlr is None:
      print(f"Error: unsupported package type: {pkg_type}")
    else:
      for name, pkg in pkgs.items():
        if args.op == MODE_LIST:
          list_package(hdlr, name, pkg)
        else:
          # other ops require an authorized github instance
          auth = Auth.Token(args.token)
          gh = Github(auth=auth)
          do_op(args.op, hdlr, gh, args.token, name, pkg)

  return 0


if __name__ == "__main__":

  map_modes = {
      "list": MODE_LIST,
      "info": MODE_INFO,
      "download": MODE_DOWNLOAD,
      "update": MODE_UPDATE
    }

  ensure_binaries([])
  parser = argparse.ArgumentParser(prog='ghr-util', description='Utility for updating packages/binaries from Github releases', epilog='')
  parser.add_argument("op", choices=list(map_modes), help="Operation to perform.")
  parser.add_argument("--token", default=None, help="Github access token with read privledge (required if op is not 'list')")
  parser.add_argument("file", nargs='?', default=None, help="Configuration file (defaults to $XDG_CONFIG_DIR/config/host-config/ghr.yaml).")
  args = parser.parse_args()
  args.op = map_modes[args.op]
  if args.op != MODE_LIST and (args.token is None or len(args.token) == 0):
    raise argparse.ArgumentError("token is a required argument for info, download, and update operations")
  exit(main(args))
